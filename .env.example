# Copy to .env.local and fill in. Local mode needs no keys (uses a mock model).
MAESTRO_MODE=local
MAESTRO_DATA_MODE=demo

# Primary model — free at https://aistudio.google.com
GEMINI_API_KEY=
# Fallback model — free at https://console.groq.com
GROQ_API_KEY=

# Per model-call timeout (ms) before retry/fallback
MAESTRO_TIMEOUT_MS=45000
# Set "true" to force Gemini failure and watch the fallback to Groq live
MAESTRO_SIMULATE_GEMINI_FAIL=

# Bedrock mode only (pay-per-token, not free)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
